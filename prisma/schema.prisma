generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  USER
  ADMIN
}

enum UploadStatus {
  UPLOADED
  PARSING
  PARSED
  ANALYZING
  ANALYZED
  PDF_GENERATED
  FAILED
}

enum AttributeDataType {
  TEXT
  NUMBER
  DATE
  BOOLEAN
  CURRENCY
  PERCENT
  UNKNOWN
}

enum AiAnalysisStatus {
  PENDING
  RUNNING
  SUCCESS
  FAILED
}

model User {
  id                String               @id @default(cuid())
  email             String               @unique
  passwordHash      String?
  name              String
  fullName          String?
  role              UserRole             @default(USER)
  isActive          Boolean              @default(true)
  avatar            String               @default("")
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  tokens            Token[]
  uploads           UploadedFile[]
  parsedSheets      ParsedSheet[]
  extractedRows     ExtractedRow[]
  attributes        FinancialAttribute[]
  attributeVersions AttributeVersion[]
  analyses          AiAnalysis[]
  templates         ReportTemplate[]
  reports           GeneratedReport[]
  auditLogs         AuditLog[]

  @@index([role])
}

model Token {
  id        String   @id @default(cuid())
  userId    String   @unique
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([expiresAt])
}

model UploadedFile {
  id           String               @id @default(cuid())
  userId       String
  user         User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  originalName String
  storedName   String?
  mimeType     String?
  extension    String?
  sizeBytes    Int
  checksum     String?
  status       UploadStatus         @default(UPLOADED)
  errorMessage String?
  rawFilePath  String?
  rawFileData  Bytes?
  uploadedAt   DateTime             @default(now())
  parsedAt     DateTime?
  analyzedAt   DateTime?
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  sheets       ParsedSheet[]
  rows         ExtractedRow[]
  attributes   FinancialAttribute[]
  versions     AttributeVersion[]   @relation("UploadAttributeVersions")
  analyses     AiAnalysis[]
  reports      GeneratedReport[]

  @@index([userId, uploadedAt])
  @@index([status])
}

model ParsedSheet {
  id             String               @id @default(cuid())
  userId         String
  uploadId       String
  user           User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  upload         UploadedFile         @relation(fields: [uploadId], references: [id], onDelete: Cascade)
  sheetName      String
  detectedRange  String?
  rowCount       Int                  @default(0)
  columnCount    Int                  @default(0)
  headerRowIndex Int?
  headers        Json?
  rawRows        Json?
  normalizedRows Json?
  createdAt      DateTime             @default(now())
  rows           ExtractedRow[]
  attributes     FinancialAttribute[]

  @@index([userId, uploadId])
  @@index([sheetName])
}

model ExtractedRow {
  id              String               @id @default(cuid())
  userId          String
  uploadId        String
  sheetId         String
  user            User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  upload          UploadedFile         @relation(fields: [uploadId], references: [id], onDelete: Cascade)
  sheet           ParsedSheet          @relation(fields: [sheetId], references: [id], onDelete: Cascade)
  rowIndex        Int
  rowIdentityHash String
  rawJson         Json
  normalizedJson  Json?
  detectedDate    DateTime?
  detectedAmount  Decimal?             @db.Decimal(20, 4)
  detectedType    String?
  createdAt       DateTime             @default(now())
  attributes      FinancialAttribute[]

  @@index([userId, uploadId])
  @@index([rowIdentityHash])
}

model FinancialAttribute {
  id                 String             @id @default(cuid())
  userId             String
  uploadId           String
  sheetId            String?
  rowId              String?
  user               User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  upload             UploadedFile       @relation(fields: [uploadId], references: [id], onDelete: Cascade)
  sheet              ParsedSheet?       @relation(fields: [sheetId], references: [id], onDelete: SetNull)
  row                ExtractedRow?      @relation(fields: [rowId], references: [id], onDelete: SetNull)
  identityKey        String
  attributeKey       String
  label              String
  dataType           AttributeDataType  @default(UNKNOWN)
  sheetName          String?
  rowIndex           Int?
  columnIndex        Int?
  periodDate         DateTime?
  latestVersionId    String?
  currentValueRaw    String?
  currentValueText   String?
  currentValueNumber Decimal?           @db.Decimal(20, 4)
  currentValueDate   DateTime?
  currentValueJson   Json?
  rowIdentityHash    String?
  attributeHash      String?
  versionCount       Int                @default(0)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  versions           AttributeVersion[]

  @@unique([userId, identityKey])
  @@index([userId, attributeKey])
  @@index([userId, uploadId])
  @@index([rowIdentityHash])
}

model AttributeVersion {
  id                String             @id @default(cuid())
  userId            String
  sourceUploadId    String
  attributeId       String
  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  sourceUpload      UploadedFile       @relation("UploadAttributeVersions", fields: [sourceUploadId], references: [id], onDelete: Cascade)
  attribute         FinancialAttribute @relation(fields: [attributeId], references: [id], onDelete: Cascade)
  versionNo         Int
  isLatest          Boolean            @default(true)
  validFrom         DateTime           @default(now())
  validTo           DateTime?
  valueRaw          String?
  valueText         String?
  valueNumber       Decimal?           @db.Decimal(20, 4)
  valueDate         DateTime?
  valueJson         Json?
  valueHash         String
  periodDate        DateTime?
  sourceSheetName   String?
  sourceRowIndex    Int?
  sourceColumnIndex Int?
  createdAt         DateTime           @default(now())

  @@unique([attributeId, versionNo])
  @@index([userId, sourceUploadId])
  @@index([attributeId, isLatest])
  @@index([valueHash])
}

model AiAnalysis {
  id             String            @id @default(cuid())
  userId         String
  uploadId       String
  user           User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  upload         UploadedFile      @relation(fields: [uploadId], references: [id], onDelete: Cascade)
  status         AiAnalysisStatus  @default(PENDING)
  modelName      String
  promptVersion  String            @default("v1")
  inputSummary   Json?
  requestPayload Json?
  resultJson     Json?
  resultText     String?
  errorMessage   String?
  tokenUsage     Json?
  startedAt      DateTime?
  completedAt    DateTime?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  reports        GeneratedReport[]

  @@index([userId, uploadId])
  @@index([status])
}

model ReportTemplate {
  id           String            @id @default(cuid())
  userId       String
  user         User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  name         String
  description  String?
  templateJson Json
  htmlTemplate String?
  isDefault    Boolean           @default(false)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  reports      GeneratedReport[]

  @@index([userId])
}

model GeneratedReport {
  id          String          @id @default(uuid())
  userId      String
  uploadId    String?
  analysisId  String?
  templateId  String?
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  upload      UploadedFile?   @relation(fields: [uploadId], references: [id], onDelete: SetNull)
  analysis    AiAnalysis?     @relation(fields: [analysisId], references: [id], onDelete: SetNull)
  template    ReportTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  title       String
  fileName    String
  mimeType    String          @default("application/pdf")
  sizeBytes   Int
  pdfData     Bytes
  reportJson  Json?
  range       String?
  generatedAt DateTime        @default(now())
  createdAt   DateTime        @default(now())

  @@index([userId, generatedAt])
  @@index([uploadId])
  @@index([analysisId])
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action     String
  entityType String?
  entityId   String?
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([action])
}
